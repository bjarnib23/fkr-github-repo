<?php

/**
 * @file
 * FKR Booking module hooks.
 */

/**
 * Implements hook_mail().
 */
function fkr_booking_mail($key, &$message, $params) {
  $message['headers']['Content-Type'] = 'text/plain; charset=UTF-8; format=flowed';

  switch ($key) {
    case 'booking_confirmation':
      $message['subject'] = 'Bókun móttekin - FKR Reykjavík';
      $message['body'][] = 'Hæ ' . $params['nafn'] . ',';
      $message['body'][] = '';
      $message['body'][] = 'Við höfum móttekið bókunarbeiðni þína. Við munum hafa samband fljótlega til að staðfesta tímann.';
      $message['body'][] = '';
      $message['body'][] = 'Upplýsingar um bókun:';
      $message['body'][] = 'Nafn: ' . $params['nafn'];
      if (!empty($params['panta'])) {
        $message['body'][] = 'Pöntun: ' . $params['panta'];
      }
      if (!empty($params['dagsetning'])) {
        $message['body'][] = 'Dagsetning: ' . $params['dagsetning'];
      }
      if (!empty($params['athugasemd'])) {
        $message['body'][] = 'Athugasemd: ' . $params['athugasemd'];
      }
      $message['body'][] = '';
      $message['body'][] = 'Kveðja,';
      $message['body'][] = 'FKR Reykjavík';
      break;

    case 'gjafabref_confirmation':
      $message['subject'] = 'Gjafabréf FKR Reykjavík - Greiðsla móttekin';
      $message['body'][] = 'Hæ ' . $params['nafn_kaupanda'] . ',';
      $message['body'][] = '';
      $message['body'][] = 'Greiðsla fyrir gjafabréf hefur tekist. Gjafabréfið verður sent á þig fljótlega.';
      $message['body'][] = '';
      $message['body'][] = 'Upplýsingar um gjafabréf:';
      $message['body'][] = 'Upphæð: ' . $params['upphaed'];
      $message['body'][] = 'Kaupandi: ' . $params['nafn_kaupanda'];
      $message['body'][] = 'Viðtakandi: ' . $params['nafn_vidtakanda'];
      if (!empty($params['athugasemd'])) {
        $message['body'][] = 'Athugasemd: ' . $params['athugasemd'];
      }
      $message['body'][] = '';
      $message['body'][] = 'Kveðja,';
      $message['body'][] = 'FKR Reykjavík';
      break;
  }
}
